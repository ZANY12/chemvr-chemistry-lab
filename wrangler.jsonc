{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "chemvr-chemistry-lab",
  "compatibility_date": "2026-04-15",
  "observability": {
    "enabled": true
  },
  "build": {
    "command": "npm run build"
  },
  "assets": {
    "directory": "dist/public",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
